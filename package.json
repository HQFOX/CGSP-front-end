{
	"name": "cgsp-front-end",
	"version": "1.0.1",
	"private": true,
	"engines": {
		"node": "22.x"
	},
	"scripts": {
		"dev": "next dev",
		"dev:prod": "dotenv -e .env.production -- next dev",
		"build": "next build",
		"start": "next start",
		"test": "vitest",
		"lint": "next lint",
		"lint:fix": "eslint --fix",
		"format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc.json --end-of-line lf",
		"prepare": "husky",
		"docker-build": "npm run build && docker build -t nextapp .",
		"docker-push": "npm run docker-build && docker image push hqfox/nextapp",
		"size": "size-limit"
	},
	"size-limit": [
		{
			"name": "Shared app bundle",
			"path": ".next/static/chunks/pages/_app-*.js"
		},
		{
			"name": "Home page",
			"path": ".next/static/chunks/pages/index-*.js"
		},
		{
			"name": "Projects page",
			"path": ".next/static/chunks/pages/projects-*.js"
		},
		{
			"name": "Updates page",
			"path": ".next/static/chunks/pages/updates-*.js"
		}
	],
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@emotion/css": "^11.13.5",
		"@emotion/react": "^11.13.5",
		"@emotion/styled": "^11.13.5",
		"@fontsource/roboto": "^5.2.9",
		"@mui/icons-material": "^6.1.9",
		"@mui/material": "^6.1.9",
		"@next/third-parties": "^15.5.19",
		"@number-flow/react": "^0.6.0",
		"@phosphor-icons/react": "^2.1.10",
		"@tanstack/react-table": "^8.21.3",
		"cgsp-front-end": "file:",
		"echarts": "^6.1.0",
		"formik": "^2.4.9",
		"i18next": "^26.0.10",
		"js-cookie": "^3.0.8",
		"jwt-decode": "^4.0.0",
		"leaflet": "^1.9.4",
		"next": "^15.5.19",
		"next-i18next": "^16.0.7",
		"number-flow": "^0.6.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-i18next": "^17.0.8",
		"react-intersection-observer": "^10.0.2",
		"react-leaflet": "^4.2.1",
		"sharp": "^0.35.1",
		"yup": "^1.7.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^20.5.3",
		"@next/bundle-analyzer": "^16.2.6",
		"@next/eslint-plugin-next": "^15.5.19",
		"@size-limit/file": "^12.1.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/js-cookie": "^3.0.6",
		"@types/leaflet": "^1.9.21",
		"@types/node": "26.0.0",
		"@types/react": "18.3.12",
		"@types/react-dom": "18.3.1",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.59.3",
		"@vitejs/plugin-react": "^6.0.2",
		"dotenv-cli": "^11.0.0",
		"eslint": "^9.15.0",
		"eslint-config-next": "^15.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-react": "^7.37.2",
		"eslint-plugin-react-hooks": "^5.0.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.1",
		"size-limit": "^12.1.0",
		"typescript": "5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.7"
	}
}
